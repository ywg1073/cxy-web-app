<?xml version="1.0" encoding="utf-8"?>
<!-- 会话过期弹窗：卡片式设计 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:background="@drawable/card_bg_rounded"
    android:orientation="vertical"
    android:padding="28dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="登录状态已失效"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:lineSpacingExtra="4dp"
        android:text="不重新登录也能看题目，不过无法收藏和记录学习进度。&#10;&#10;请重新登录以使用完整功能。"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <Button
        android:id="@+id/btnRelogin"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="28dp"
        android:background="@drawable/btn_accent_rounded"
        android:text="重新登录"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/btn_outline_rounded"
        android:text="取消"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

</LinearLayout>