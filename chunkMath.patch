+var renderMathTimer = null;
+function asyncRenderMathList(cardsHtml, app) {
+  if (renderMathTimer) clearTimeout(renderMathTimer);
+  
+  // Find unrendered cards
+  var cards = app.querySelectorAll('.card-preview:not(.rendered)');
+  var index = 0;
+  
+  function processChunk() {
+    var chunkEnd = Math.min(index + 10, cards.length); // render 10 cards per frame
+    while (index < chunkEnd) {
+      var card = cards[index];
+      try{ renderMathInElement(card, KATEX_OPTIONS); }catch(e){}
+      card.classList.add('rendered');
+      index++;
+    }
+    
+    if (index < cards.length) {
+      renderMathTimer = setTimeout(processChunk, 16); // yield to browser
+    }
+  }
+  
+  if (cards.length > 0) processChunk();
+}
